# =============================================================
# ขนมแม่ — Stock Management — Environment Variables Example
# คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าจริง
# สำคัญ: ห้าม commit ไฟล์ .env / .env.local ขึ้น Git เด็ดขาด!
# =============================================================

# ─── Supabase ────────────────────────────────────────────────
# สร้าง project ใหม่ที่ https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# service_role key — ใช้เฉพาะ server-side (API routes) เท่านั้น ห้าม expose ฝั่ง client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Timezone ────────────────────────────────────────────────
TZ=Asia/Bangkok

# ─── FoodStory (owner.foodstory.co) — POS sync ───────────────
# auth แบบ MVP: copy จาก DevTools → request "getdata" → tab Headers
#   FOODSTORY_COOKIE = ค่าเต็มของ header "Cookie" (มี laravel session — ความลับ อายุสั้น)
#   FOODSTORY_CSRF   = ค่าของ header "X-CSRF-Token"
# token หมดอายุเมื่อ logout/นานไป → copy ใหม่ (เฟสถัดไปค่อยทำ auto-login)
FOODSTORY_COOKIE=
FOODSTORY_CSRF=
FOODSTORY_YEAR=2026
FOODSTORY_MONTH=6
